# CPU-only Dockerfile for AutoResearch SDPA - Experiment Samples API
# This API serves pre-computed samples from experiment directories
# No model loading or inference is performed - just reads text files

FROM python:3.10-slim

# Set working directory
WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/usr/local/bin:${PATH}"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency installation
RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    cp /root/.local/bin/uv /usr/local/bin/uv && \
    cp /root/.local/bin/uvx /usr/local/bin/uvx && \
    chmod +x /usr/local/bin/uv /usr/local/bin/uvx

# Create non-root user BEFORE copying files (for proper ownership)
# User UID 1000 as required by K8s securityContext.runAsUser
RUN useradd -m -u 1000 api

# Copy ONLY the API server (no inference.py, no prepare.py needed)
COPY --chown=api:api api_server.py .

# Install FastAPI and uvicorn only (no torch, no inference dependencies)
RUN uv pip install --system fastapi uvicorn[standard] pydantic==2.10.6 starlette typing-extensions

# Create directories for volume mounts with correct ownership
RUN mkdir -p /app/checkpoints && chown api:api /app/checkpoints

# Switch to non-root user for running the application
USER api

# Health check - curl is available in python:3.10-slim base image
HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Expose API port
EXPOSE 8000

# Run the FastAPI server
CMD ["python", "api_server.py"]
